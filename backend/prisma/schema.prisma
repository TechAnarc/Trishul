// Trishul Platform - Prisma Database Schema
// Travel Agency Intelligence Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DRIVER
}

enum MfaMethod {
  TOTP
  EMAIL_OTP
  SMS_OTP
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
  AVAILABLE
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAUSED
}

enum ExpenseCategory {
  FUEL
  TOLL
  FOOD
  MAINTENANCE
  ACCOMMODATION
  PARKING
  PERMIT
  POLICE
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ── Models ────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(DRIVER)
  phone        String?
  isActive     Boolean    @default(true)
  isMfaEnabled Boolean    @default(false)
  mfaMethod    MfaMethod?
  mfaSecret    String? // Encrypted TOTP secret
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  driver       Driver?
  adminProfile Admin?

  @@index([email])
  @@index([role])
  @@map("users")
}

model Driver {
  id             String    @id @default(uuid())
  userId         String    @unique
  licenseNumber  String    @unique
  licenseExpiry  DateTime?
  experience     Int       @default(0) // years
  isAvailable    Boolean   @default(true)
  emergencyPhone String?
  address        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  adminId String

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin           Admin               @relation(fields: [adminId], references: [id], onDelete: Cascade)
  assignedVehicle VehicleAssignment[]
  trips           Trip[]
  expenses        Expense[]

  @@index([userId])
  @@map("drivers")
}

model Admin {
  id         String   @id @default(uuid())
  userId     String   @unique
  agencyName String
  createdAt  DateTime @default(now())

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  drivers  Driver[]
  vehicles Vehicle[]
  trips    Trip[]
  expenses Expense[]
  invoices Invoice[]

  @@map("admins")
}

model Vehicle {
  id              String        @id @default(uuid())
  vehicleNumber   String        @unique
  model           String
  make            String?
  year            Int?
  color           String?
  fuelType        FuelType      @default(DIESEL)
  seatingCapacity Int?
  status          VehicleStatus @default(AVAILABLE)
  insuranceExpiry DateTime?
  permitExpiry    DateTime?
  fitnessExpiry   DateTime?
  pollutionExpiry DateTime?
  odometerReading Float         @default(0) // km
  ratePerKm       Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  adminId String

  // Relations
  admin       Admin               @relation(fields: [adminId], references: [id], onDelete: Cascade)
  assignments VehicleAssignment[]
  trips       Trip[]

  @@index([vehicleNumber])
  @@index([status])
  @@map("vehicles")
}

model VehicleAssignment {
  id         String    @id @default(uuid())
  driverId   String
  vehicleId  String
  assignedAt DateTime  @default(now())
  releasedAt DateTime?
  isActive   Boolean   @default(true)

  // Relations
  driver  Driver  @relation(fields: [driverId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([driverId])
  @@index([vehicleId])
  @@map("vehicle_assignments")
}

model Trip {
  id                String     @id @default(uuid())
  tripCode          String     @unique @default(cuid()) // For public tracking URL
  driverId          String
  vehicleId         String
  clientName        String?
  clientPhone       String?
  startLocation     String
  endLocation       String
  waypoints         Json? // Array of intermediate stops
  distance          Float? // km (actual, filled after trip)
  estimatedDistance Float? // km (estimated before trip)
  status            TripStatus @default(SCHEDULED)
  startTime         DateTime?
  endTime           DateTime?
  scheduledAt       DateTime?
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  adminId String

  // Relations
  admin        Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  driver       Driver        @relation(fields: [driverId], references: [id])
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id])
  expenses     Expense[]
  invoice      Invoice?
  locationLogs LocationLog[]

  @@index([driverId])
  @@index([vehicleId])
  @@index([status])
  @@index([tripCode])
  @@map("trips")
}

model LocationLog {
  id        String   @id @default(uuid())
  tripId    String
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  altitude  Float?
  timestamp DateTime @default(now())

  // Relations
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([timestamp])
  @@map("location_logs")
}

model Expense {
  id         String          @id @default(uuid())
  tripId     String
  driverId   String
  category   ExpenseCategory
  amount     Float
  note       String?
  receiptUrl String?
  isVerified Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  adminId String

  // Relations
  admin  Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([tripId])
  @@index([driverId])
  @@index([category])
  @@map("expenses")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @default(cuid())
  tripId        String        @unique
  clientName    String?
  clientEmail   String?
  clientPhone   String?
  totalDistance Float
  ratePerKm     Float
  baseFare      Float
  tollCharges   Float         @default(0)
  otherCharges  Float         @default(0)
  discount      Float         @default(0)
  tax           Float         @default(0)
  totalFare     Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  adminId String

  // Relations
  admin    Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  trip     Trip      @relation(fields: [tripId], references: [id])
  payments Payment[]

  @@index([status])
  @@index([invoiceNumber])
  @@map("invoices")
}

model Payment {
  id            String        @id @default(uuid())
  invoiceId     String
  amount        Float
  method        String // cash, upi, card, bank_transfer
  transactionId String?
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
