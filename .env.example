# Trishul Platform - Environment Variables

# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT .env TO VERSION CONTROL
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=Trishul

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/trishul_db

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── MFA ──────────────────────────────────────────────────────
MFA_APP_NAME=TrishulTravels
MFA_TOTP_SECRET=your_totp_secret

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@trishul.app

# ── SMS (Twilio) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Super Admin Seed Credentials ──────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@trishul.app
SUPER_ADMIN_PASSWORD=Trishul@SuperAdmin2024!
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=+919999999999

# ── CORS & Client ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Socket.io ─────────────────────────────────────────────────
SOCKET_CORS_ORIGIN=*

# ── Maps / Tracking ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
